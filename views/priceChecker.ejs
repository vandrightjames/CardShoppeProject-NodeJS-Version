<!DOCTYPE html>
<html>
<%- include('html_head.ejs') %>

<body>

<%- include('head.ejs') %>

<form id="add_to_watchlist">

    <input id="game_choice" type="text" list="games" value="" placeholder="Game (Id)" />
    <datalist id="games">
        <% for(let i = 0; i < games.length;i++){%>
            <option data-id="<%=games[i].id%>" value="<%=games[i].name%>"><%=games[i].name%> (<%=games[i].id%>)</option>
        <% } %>
    </datalist>

    <input id="set_choice" type="text" list="sets" placeholder="Set (Id)" />
    <datalist id="sets">
        
    </datalist>


    <button type="button" id="submit_btn">Add to Watchlist</button>  

</form>
<%- include('foot.ejs') %>

<script>
    game_c = document.getElementById("game_choice");
    game_c.addEventListener("input", async function(event){
        try{
            let chosen_option = document.querySelector(`option[value=${game_c.value}]`);
            const response = fetch(`PriceChecker/Sets/${chosen_option.dataset.id}`)
            if(!response.ok){
                throw new Error(`Response Status: ${response.status}`);
            }
            
        }
        catch(err){
            console.log(err);
        }
    });

</script>

</body>
</html>